						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{register_mobile}}\",\n  \"type\": \"vendor_register\"\n}" },
						"url": "{{base_url}}/api/v2/auth/send-otp",
						"description": "**POST** `/api/v2/auth/send-otp`\n\n**Body:** `{ \"mobile\", \"type\": \"vendor_register\" }`" }
				},
				{
					"name": "Verify OTP (Vendor Login)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
