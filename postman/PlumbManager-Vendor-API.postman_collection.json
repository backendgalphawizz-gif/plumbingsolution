		{
			"name": "01 — Authentication",
			"description": "OTP-based vendor login and registration.\n\n**Login:** `vendor_login` | **Register:** `vendor_register`",
			"item": [
				{
					"name": "Send OTP (Vendor Login)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
						"if (j.data?.otp) { pm.collectionVariables.set('otp', String(j.data.otp)); pm.environment.set('otp', String(j.data.otp)); console.log('OTP: ' + j.data.otp); }",
						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"type\": \"vendor_login\"\n}" },
						"url": "{{base_url}}/api/v2/auth/send-otp",
						"description": "**POST** `/api/v2/auth/send-otp`\n\n**Body:** `{ \"mobile\", \"type\": \"vendor_login\" }`" }
				},
				{
					"name": "Send OTP (Vendor Register)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
