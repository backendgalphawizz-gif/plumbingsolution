							{ "key": "shop_logo", "type": "file", "src": [] },
							{ "key": "pan_card", "type": "file", "src": [] },
							{ "key": "account_holder_name", "value": "Sarah", "type": "text" },
							{ "key": "account_number", "value": "951234587254", "type": "text" },
							{ "key": "ifsc_code", "value": "HDFC0001234", "type": "text" },
							{ "key": "bank_name", "value": "Bank Of Mirzapur", "type": "text" },
							{ "key": "account_type", "value": "savings", "type": "text" }
						] },
						"url": "{{base_url}}/api/v2/auth/register",
						"description": "Multipart — requires OTP verified first. Vendor status = pending." }
				},
				{
					"name": "Logout",
					"request": { "method": "POST", "url": "{{base_url}}/api/v2/auth/logout",
						"description": "**POST** `/api/v2/auth/logout` — requires Bearer token" }
				}
			]
		},
