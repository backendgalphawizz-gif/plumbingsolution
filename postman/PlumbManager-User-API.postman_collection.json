		{
			"name": "01 — Authentication",
			"description": "OTP-based login and registration.\n\n**Login:** send-otp (`type: login`) → verify-otp (`type: login`)\n\n**Register:** send-otp (`type: register`) → verify-otp (`type: register`) → register",
			"item": [
				{
					"name": "Send OTP (Login)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
						"if (j.data?.otp) { pm.collectionVariables.set('otp', String(j.data.otp)); pm.environment.set('otp', String(j.data.otp)); console.log('OTP: ' + j.data.otp); }",
						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"type\": \"login\"\n}" },
						"url": "{{base_url}}/api/v1/auth/send-otp",
						"description": "**POST** `/api/v1/auth/send-otp`\n\n**Body:** `{ \"mobile\": \"9876500001\", \"type\": \"login\" }`\n\nReturns 4-digit OTP in `data.otp`. Mobile must already be registered." }
				},
				{
					"name": "Send OTP (Register)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
						"if (j.data?.otp) { pm.collectionVariables.set('otp', String(j.data.otp)); pm.environment.set('otp', String(j.data.otp)); console.log('OTP: ' + j.data.otp); }",
						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{register_mobile}}\",\n  \"type\": \"register\"\n}" },
						"url": "{{base_url}}/api/v1/auth/send-otp",
						"description": "**POST** `/api/v1/auth/send-otp`\n\n**Body:** `{ \"mobile\": \"9123456789\", \"type\": \"register\" }`\n\nReturns 4-digit OTP. Mobile must NOT be registered yet." }
				},
				{
					"name": "Verify OTP (Login)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
						"if (j.data?.token) { pm.collectionVariables.set('token', j.data.token); pm.environment.set('token', j.data.token); }",
						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"otp\": {{otp}},\n  \"type\": \"login\",\n  \"fcm_token\": \"{{fcm_token}}\"\n}" },
						"url": "{{base_url}}/api/v1/auth/verify-otp",
						"description": "**POST** `/api/v1/auth/verify-otp`\n\n**Body:** `{ \"mobile\", \"otp\", \"type\": \"login\" }`\n\nReturns `token` + `user` on success (same as login)." }
				},
				{
					"name": "Verify OTP (Register)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
						"pm.test('Verified', () => pm.expect(j.data?.verified).to.eql(true));",
						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{register_mobile}}\",\n  \"otp\": {{otp}},\n  \"type\": \"register\"\n}" },
						"url": "{{base_url}}/api/v1/auth/verify-otp",
						"description": "**POST** `/api/v1/auth/verify-otp`\n\n**Body:** `{ \"mobile\", \"otp\", \"type\": \"register\" }`\n\nReturns `{ verified: true }`. Then call **Register** to complete signup." }
				},
				{
					"name": "Login",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"const j = pm.response.json();",
						"if (j.data?.token) { pm.collectionVariables.set('token', j.data.token); pm.environment.set('token', j.data.token); }",
						"pm.test('OK', () => pm.response.to.have.status(200));"
					]}}],
					"request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"mobile\": \"{{mobile}}\",\n  \"otp\": {{otp}},\n  \"fcm_token\": \"{{fcm_token}}\"\n}" },
						"url": "{{base_url}}/api/user/auth/login",
						"description": "**POST** `/api/user/auth/login`\n\n**Body:** `{ \"mobile\", \"otp\" }`\n\nAlternative to Verify OTP (Login). OTP can be number or string." }
				},
				{
					"name": "Register (Customer)",
